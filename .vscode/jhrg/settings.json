{
    // Edit for the Hyrax project.  The prefix variable is used to set the PATH for both the C++ extension and the terminal.
    "prefix": "/Users/jimg/src/opendap/hyrax_git/build",
    "PATH": "${config:prefix}/bin:${config:prefix}/deps/bin:${env:PATH}",
    "C_Cpp.default.configurationProvider": "ms-vscode.makefile-tools",
    "C_Cpp.default.compileCommands": "${workspaceFolder}/compile_commands.json",
    "C_Cpp.default.cppStandard": "c++14",
    "C_Cpp.default.intelliSenseMode": "macos-clang-arm64",
    "terminal.integrated.env.osx": {
        "prefix": "${config:prefix}",
        "PATH": "${config:PATH}"
    },
    "terminal.integrated.env.linux": {
        "prefix": "${config:prefix}",
        "PATH": "${config:PATH}"
    }
}